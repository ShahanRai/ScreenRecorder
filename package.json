{
  "name": "screen-recorder",
  "version": "1.1.0",
  "description": "A portable screen recording application",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "keywords": [],
  "author": "Shahan Rai",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.screenrecorder.portable",
    "icon": "build/icon.png",
    "win": {
      "target": "portable",
      "icon": "build/icon.png",
      "verifyUpdateCodeSignature": false
    },
    "directories": {
      "output": "build_output"
    }
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0"
  }
}
